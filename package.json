{
  "name": "@currentjs/provider-mysql",
  "version": "0.1.1",
  "description": "MySQL database provider for currentjs framework",
  "license": "LGPL-3.0",
  "author": "Konstantin Zavalny",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/currentjs/provider-mysql.git"
  },
  "homepage": "https://github.com/currentjs/provider-mysql",
  "bugs": "https://github.com/currentjs/provider-mysql/issues",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist dist-test",
    "prepack": "npm run build",
    "test:build": "tsc -p tsconfig.test.json",
    "test": "npm run test:build && node --test dist-test/tests/unit/*.test.js",
    "test:all": "npm run test:build && node --test dist-test/tests/unit/*.test.js dist-test/tests/integration/*.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "mysql2": "^3.6.0",
    "@currentjs/provider": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "typescript": "^5.6.3"
  }
}
